# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_ENV=production
DJANGO_SETTINGS_MODULE=config.settings
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# DEBUG=True يعرّض تتبع الأخطاء (traceback) للمستخدم — للتطوير المحلي فقط (DJANGO_ENV=development)

# منفذ التطبيق الداخلي (Dokploy) — غيّره لكل شركة/مشروع (مثال SEED: 8088)
PORT=8088

# Hosts allowed to serve the app (comma-separated) — required in production
# أضف IP السيرفر إن وصل وكيل البصمة عبر http://IP:port (DisallowedHost بدونها)
ALLOWED_HOSTS=your-domain.com,YOUR_SERVER_IP,localhost,127.0.0.1
# يُدمَج تلقائياً في الإنتاج إن لم يكن ضمن ALLOWED_HOSTS (انظر production.py)
SERVER_PUBLIC_IP=YOUR_SERVER_IP
# مسار لوحة Django Admin (بدون /admin الافتراضي)
DJANGO_ADMIN_URL=secure-control-panel-2026
# Must match your public URL scheme (https:// when TLS is enabled)
CSRF_TRUSTED_ORIGINS=http://YOUR_SERVER_IP:8088

# ─── Database (PostgreSQL — Neon فقط) ─────────────────────────────────────────
# قاعدة جديدة لكل شركة/نسخ مشروع — نفس DATABASE_URL محلياً وفي Dokploy.
# لا تشارك Neon مع شركة أخرى. لا تستخدم Postgres منفصلاً في Dokploy مع Neon.
#
# من https://console.neon.tech — استخدم نقطة *pooler* وليس direct.
# المنطقة الموصى بها مع VPS باريس: eu-west-2 (London) أو eu-central-1 (Frankfurt)
# '@' داخل كلمة المرور → %40
# إن فشل الاتصال: احذف &channel_binding=require من نهاية الرابط
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require
DB_SSLMODE=require

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP:8088

# ─── Security ─────────────────────────────────────────────────────────────────
# SECRET_KEY: 32+ حرفاً (50+ مُوصى به) — Django + جلسات (لا ترفعه إلى Git)
# JWT_SECRET: (اختياري) مفتاح توقيع JWT منفصل؛ إن تُرك فارغاً يُستخدم SECRET_KEY
# EVOLUTION_API_KEY / ATTENDANCE_AGENT_API_KEY / R2_* : Environment فقط — أبداً في Git
# ─── HTTPS (بعد تفعيل SSL على Dokploy/Nginx) ─────────────────────────────────
# USE_HTTPS=true
# SECURE_SSL_REDIRECT=true
# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true
# CSRF_TRUSTED_ORIGINS=https://your-domain.com
# CORS_ALLOWED_ORIGINS=https://your-domain.com
# تحقق: curl -s "https://hr.alrsheed.net/health/?proxy=1" → x_forwarded_proto=https
# دليل SSL كامل: docs/نشر-SSL-hr.alrsheed.net.md

# نشر مع TLS: CSRF_TRUSTED_ORIGINS=https://your-domain.com و USE_HTTPS=true
# على HTTP لا تضبط SESSION_COOKIE_SECURE=true — يمنع تسجيل الدخول (يُعاد تلقائياً إلى false)
USE_HTTPS=true
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_EXPIRE_AT_BROWSER_CLOSE=true

# ─── JWT (API) ───────────────────────────────────────────────────────────────
# JWT_ACCESS_TOKEN_MINUTES=15
# JWT_REFRESH_TOKEN_DAYS=7
# JWT_SECRET=long-random-jwt-signing-key-separate-from-secret-key
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=false

# First-deploy superuser (required once; never use a default password)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-to-a-strong-password
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com

# وكيل البصمة — يُفضّل مفتاح لكل جهاز؛ المفتاح العام لا يعرض قائمة الأجهزة في الإنتاج
# ATTENDANCE_AGENT_API_KEY=
# AGENT_GLOBAL_KEY_LIST_DEVICES=false
# API rate limits (optional — DRF throttling)
# DRF_LOGIN_THROTTLE=20/hour
# DRF_ANON_THROTTLE=100/hour
# DRF_USER_THROTTLE=1000/hour

# django-ratelimit (يستخدم REDIS_URL أو LocMem — Redis موصى به مع عدة workers)
# RATELIMIT_ENABLE=true
# RATELIMIT_LOGIN_IP=20/h
# RATELIMIT_LOGIN_USER=20/h
# RATELIMIT_PASSWORD_CHANGE=10/h
# RATELIMIT_API_TOKEN_IP=30/h
# RATELIMIT_HEALTH_IP=120/m

# ─── Cache / Redis (production — عدة workers) ─────────────────────────────────
# موصى به في الإنتاج مع Gunicorn بعدة workers (بدونها LocMemCache + تحذير في السجلات)
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_KEY_PREFIX=hr
# REDIS_CACHE_TIMEOUT=300
# مدة تخزين عدادات الشريط الجانبي (ثانية) — يقلّل استعلامات COUNT
# SIDEBAR_COUNTS_CACHE_TTL=45
# DASHBOARD_CACHE_TTL=120
# SETUP_CACHE_TTL=3600

# ─── أداء الملفات الثابتة / النشر ───────────────────────────────────────────
# WHITENOISE_MAX_AGE=31536000
# collectstatic يُنفَّذ تلقائياً عند كل تشغيل للحاوية (entrypoint)

# ─── Sentry (اختياري — أخطاء الإنتاج) ───────────────────────────────────────
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.0

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────
# Set USE_R2=True to enable R2 cloud storage, False for local filesystem storage
USE_R2=True
R2_ACCESS_KEY_ID=your-r2-access-key-here
R2_SECRET_ACCESS_KEY=your-r2-secret-key-here
R2_BUCKET_NAME=erphr
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_REGION=auto
R2_PUBLIC_DOMAIN=
# Signed URLs for private R2 objects (recommended)
R2_SIGNED_URLS=true
R2_SIGNED_URL_EXPIRE=3600
# Serve attachments through Django (/media/...) for private R2 buckets (recommended)
R2_PROXY_MEDIA=true

# ─── عن النظام (قائمة المعلومات في الشريط العلوي) ───────────────────────────
# HR_APP_DEVELOPER=اسم الشركة المطوّرة
# HR_SUPPORT_PHONE=+966531847156
# HR_APP_DESCRIPTION=وصف مختصر يظهر للمستخدمين عن النظام

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# If EMAIL_HOST is empty, console backend is used (emails printed to stdout)
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=your-email@yourdomain.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=your-email@yourdomain.com
# بريد إشعارات HR (جدول الدوام، الإفادات) — يُستخدم كمستلم افتراضي عند الإرسال
HR_NOTIFICATION_EMAIL=hr@yourdomain.com
EMAIL_TIMEOUT=30

# ─── تقرير العمليات PDF (أمر send_operations_report) ───────────────────────
# الإعدادات (البريد + الساعة) من: تهيئة النظام → تقرير العمليات المجدول
# OPERATIONS_REPORT_CRON=true
# OPERATIONS_REPORT_CRON_SCHEDULE=* * * * *   # كل دقيقة؛ الأمر يرسل عند send_time في DB

# ─── أجهزة البصمة ZKTeco (الحضور) ───────────────────────────────────────────
# BIOMETRIC_MOCK_MODE=false   # إنتاج: اتصال حقيقي بالجهاز على شبكة السيرفر/VPN
# BIOMETRIC_ZK_TIMEOUT=15
# BIOMETRIC_ZK_OMIT_PING=true

# وكيل الفرع (وسيط) — نفس المفتاح في scripts/biometric_bridge/config.env
# python manage.py generate_attendance_agent_key
# ATTENDANCE_AGENT_API_KEY=

# ─── النسخ الاحتياطي لقاعدة البيانات (إشعارات + لوحة الإدارة) ──────────────
BACKUP_STORAGE_DIR=/app/backups
# قائمة عناوين بريد مفصولة بفواصل — إذا تُركت فارغة لا يُرسَل أي بريد للنسخ
BACKUP_NOTIFY_EMAIL=
BACKUP_NOTIFY_ON_SUCCESS=true
BACKUP_NOTIFY_ON_FAILURE=true

# ─── WhatsApp / Evolution API ────────────────────────────────────────────────
# أضِف القيم في Dokploy Environment — لا تُرفَع الأسرار إلى Git
# WHATSAPP_ENABLED=true
# EVOLUTION_API_URL=http://72.61.107.230:8081
# EVOLUTION_API_KEY=your-global-api-key
# EVOLUTION_INSTANCE=hr
# WHATSAPP_DEFAULT_COUNTRY=966

# ─── نشر تلقائي (GitHub Actions → Dokploy) ─────────────────────────────────
# GitHub repo → Settings → Secrets → Actions:
#   DEPLOY_WEBHOOK_URL = رابط Deploy Webhook من Dokploy (Application → Webhooks)
#   DEPLOY_WEBHOOK_AUTH = (اختياري) Bearer token إن طلبته Dokploy
#
# Deploy: migrate runs automatically in Docker entrypoint (before Gunicorn).
# After migrate: permission registry sync, collectstatic, optional data import,
# superuser check, fix_swapped_code_name, cron (backup + operations report).
# Optional if DB wakes slowly (e.g. serverless Postgres):
# MIGRATE_MAX_RETRIES=5
# MIGRATE_RETRY_SECS=5

# نسخ تلقائي إلى R2 قبل تطبيق migrations (إضافة جداول / تغييرات على البيانات)
BACKUP_BEFORE_MIGRATE=true
# BACKUP_BEFORE_MIGRATE_REQUIRED=true   # إيقاف النشر إذا فشل النسخ قبل migrate
