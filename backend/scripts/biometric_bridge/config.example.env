# انسخ إلى config.env (لا ترفع config.env إلى Git)
# UTF-8 بدون BOM: copy config.example.env config.env

SERVER_URL=https://hr.alrsheed.net

# مفتاح خاص بجهاز واحد (موصى به) — ولّده من HR:
#   البصمة → أجهزة البصمة → «مفتاح وكيل»  أو
#   python manage.py generate_attendance_agent_key --device-id=DEVICE_ID
# يجب أن يطابق DEVICE_ID أدناه نفس رقم الجهاز في HR
AGENT_API_KEY=PUT_PER_DEVICE_KEY_HERE

# ── عدة أجهزة من مكان واحد ─────────────────────────────────────
# انسخ devices.list.example → devices.list وعدّل IPs
# انسخ device_keys.env.example → device_keys.env (مفتاح HR لكل device_id)
# أو سطر واحد:
# DEVICES=1|192.168.51.3|4370|0,2|192.168.24.59|4370|0

# ── فرع واحد (PC داخل الفرع — موصى به) ───────────────────────
# شغّل: setup_branch.ps1  أو  install_branch.bat
# DEVICE_ID=2
# DEVICE_IP=192.168.24.59
# DEVICE_PORT=4370
# COMM_KEY=0
# DEVICE_LABEL=alwaha

AGENT_ID=central-office
POLL_INTERVAL_SEC=300
TIMEOUT_SEC=20
# true (افتراضي) = لا يسحب من الجهاز إلا عند «مزامنة» من موقع HR
SYNC_ON_REQUEST_ONLY=true
# true = بعد أول مزامنة يرفع البصمات الجديدة فقط | false = سحب كامل حتى 365 يوماً
INCREMENTAL=true
# حجم دفعة الرفع — يتجنب HTTP 413 من nginx عند أول مزامنة (آلاف السجلات)
INGEST_BATCH_SIZE=150
# حد أقصى تقريبي لحجم JSON لكل طلب (KB) — يُقسّم تلقائياً عند التجاوز
INGEST_MAX_BODY_KB=600
