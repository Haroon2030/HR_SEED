# نسخ إلى backend/.env للتطوير المحلي:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/macOS)

DJANGO_ENV=development
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ─── قاعدة البيانات ─────────────────────────────────────────────────────────
# التطوير: SQLite تلقائياً في backend/db.sqlite3 — لا تضبط DATABASE_URL هنا.
# الإنتاج: PostgreSQL/Neon عبر DATABASE_URL في Dokploy فقط (DJANGO_ENV=production).

# ─── مستخدم أولي (بعد migrate) ─────────────────────────────────────────────
# python manage.py migrate
# python manage.py ensure_bootstrap_superuser
# python manage.py setup_roles --reset
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-local-only
DJANGO_SUPERUSER_EMAIL=admin@localhost
